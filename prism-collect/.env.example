# GitHub Personal Access Token (needs repo/read:org scope)
GITHUB_PAT=ghp_your_token_here

# Postgres
POSTGRES_USER=prism
POSTGRES_PASSWORD=changeme
POSTGRES_DB=prism
POSTGRES_HOST=localhost  # use 'db' inside Docker
POSTGRES_PORT=5432

# pgAdmin (optional)
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Collection tuning
PRISM_LOG_LEVEL=INFO
PRISM_BATCH_SIZE=50
PRISM_RATE_LIMIT_BUFFER=300
PRISM_DEFAULT_PAGE_SIZE=100
PRISM_REQUEST_TIMEOUT=90
PRISM_MAX_RETRIES=10
